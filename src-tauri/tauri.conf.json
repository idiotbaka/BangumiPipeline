{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BakaVip2",
  "version": "1.2.2",
  "identifier": "vip.baka.bangumipipeline.mobile",
  "build": {
    "beforeDevCommand": "npm run prepare:mobile-android && npm run dev --workspace @bangumi-pipeline/mobile",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run prepare:mobile-android && npm run build --workspace @bangumi-pipeline/mobile",
    "frontendDist": "../frontend/apps/mobile/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BakaVip2",
        "width": 390,
        "height": 844,
        "minWidth": 320,
        "minHeight": 568,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "android": {
      "minSdkVersion": 24
    }
  }
}
